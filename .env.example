# Database
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_WEBHOOK_SECRET_TOKEN=your-webhook-secret
TELEGRAM_BOT_USERNAME=your_bot_name

# Demo encryption (production: use Vercel Connect / secrets manager)
DEMO_MASTER_KEY=change-me-to-a-long-random-string

# Crypto API (sandbox only — never store in DB)
CRYPTO_API_BASE_URL=https://sandbox-api.example.com
CRYPTO_API_TOKEN=sandbox-token-from-env
CRYPTO_API_MODE=sandbox

# AI (Vercel AI Gateway OIDC on deploy, or provider keys locally)
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...
