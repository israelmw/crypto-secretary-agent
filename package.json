{
  "name": "crypto-secretary-agent",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "typecheck": "tsc --noEmit -p tsconfig.json",
